{
  "manifest_version": 3,
  "name": "WorldSBK Gap Columns",
  "version": "1.0.0",
  "description": "Adds 'Gap to 1st' and 'Gap to previous' columns to WorldSBK results tables.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.worldsbk.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
